# Safe local/demo defaults for Docker Compose.
# Copy to .env only if you want to override values locally.

APP_ENV=local
LOG_LEVEL=INFO

RAG_SYSTEM_URL=
RAG_SYSTEM_TIMEOUT_SECONDS=30

LLM_JUDGE_PROVIDER=disabled
LLM_JUDGE_MODEL=arabic-aware-judge
LLM_JUDGE_API_KEY=

SQLITE_DB_PATH=reports/evaluation_history.sqlite

OTEL_SERVICE_NAME=arabic-rag-eval-harness
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
PROMETHEUS_PORT=9100

POSTGRES_USER=rag_eval
POSTGRES_PASSWORD=rag_eval
POSTGRES_DB=rag_eval
POSTGRES_PORT=5433
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
HARNESS_API_PORT=8080
PROMETHEUS_HTTP_PORT=9090
